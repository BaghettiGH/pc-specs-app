{
  "name": "log-in-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "composer install --working-dir=backend && npm install --prefix frontend",
    "dev:backend": "php backend/artisan serve",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently -n \"backend,frontend\" -c \"magenta,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
